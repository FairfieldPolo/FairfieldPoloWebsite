# ─── Sanity CMS ───────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=your_read_token

# ─── Medusa (commerce — separate Node server) ──────────────────
# Backend URL (server-side; no trailing slash)
MEDUSA_BACKEND_URL=http://localhost:9000
# Same URL for resolving product images in the browser (must be public)
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Publishable API key from Medusa Admin → Settings → Publishable API keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=your_publishable_key
# Optional: lock catalog/pricing to a region (Medusa Admin → Settings → Regions)
# MEDUSA_DEFAULT_REGION_ID=reg_01...

# Stripe in Medusa is configured on the Medusa server (payment module).
# Optional: provider id if not using default Stripe module id
# NEXT_PUBLIC_MEDUSA_PAYMENT_PROVIDER_ID=pp_stripe_stripe

# ─── Optional service / convenience fee (display + config) ─────
# Legal/compliance: review before charging card convenience fees.
# NEXT_PUBLIC_SERVICE_FEE_ENABLED=true
# NEXT_PUBLIC_SERVICE_FEE_MODE=flat
# NEXT_PUBLIC_SERVICE_FEE_FLAT_AMOUNT=2.50
# NEXT_PUBLIC_SERVICE_FEE_MODE=percent
# NEXT_PUBLIC_SERVICE_FEE_PERCENT=3
# NEXT_PUBLIC_SERVICE_FEE_LABEL=Processing fee

# ─── Mailchimp (mailing list) ─────────────────────────────────
MAILCHIMP_API_KEY=your_api_key
MAILCHIMP_AUDIENCE_ID=your_audience_id
MAILCHIMP_SERVER_PREFIX=us1

# ─── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://fairfieldpolo.com
# When the store is deployed on a subdomain (e.g. shop.fairfieldpolo.com), set this on the
# main site so the header/footer and sitemap point there, and /store/* redirects. Leave
# empty on the shop deployment so links stay same-origin.
# NEXT_PUBLIC_SHOP_URL=https://shop.fairfieldpolo.com
# When the members site is live, point nav + redirect /members (optional):
# NEXT_PUBLIC_MEMBERS_URL=https://members.fairfield.com
NEXT_PUBLIC_INSTAGRAM_HANDLE=fairfieldpoloclub
# Behold.so — Instagram feed widget (https://app.behold.so). Connect IG → create widget → copy feed ID from embed code.
NEXT_PUBLIC_BEHOLD_WIDGET_ID=your_feed_id_from_behold_embed
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_key

# ─── Contact form (Resend for email delivery) ──────────────────
RESEND_API_KEY=your_resend_key
# Inbox that receives contact submissions (any mailbox you read)
CONTACT_EMAIL=wichitapoloclub@gmail.com
# Sender must be on a domain verified in Resend (apex vs subdomain — they must match what you verified)
# RESEND_FROM=Fairfield Polo Club Website <noreply@updates.fairfieldpolo.com>
