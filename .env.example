# ─── Sanity CMS ───────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=your_read_token

# ─── Shopify (Storefront API — /store catalog + cart) ──────────
# Dev Dashboard or Store admin → custom app → Storefront API → Install → copy access token.
# Prefer server-only token (not exposed to the browser):
SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
# Optional: public token works too (same value as above is fine):
# NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=fairfieldpolo.myshopify.com

# ─── Mailchimp (mailing list) ─────────────────────────────────
MAILCHIMP_API_KEY=your_api_key
MAILCHIMP_AUDIENCE_ID=your_audience_id
MAILCHIMP_SERVER_PREFIX=us1

# ─── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://fairfieldpolo.com
NEXT_PUBLIC_INSTAGRAM_HANDLE=fairfieldpoloclub
# Behold.so — Instagram feed widget (https://app.behold.so). Connect IG → create widget → copy feed ID from embed code.
NEXT_PUBLIC_BEHOLD_WIDGET_ID=your_feed_id_from_behold_embed
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_maps_key

# ─── Contact form (Resend for email delivery) ──────────────────
RESEND_API_KEY=your_resend_key
CONTACT_EMAIL=wichitapoloclub@gmail.com
