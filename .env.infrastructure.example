# Fairfield Polo project context (repo root).
# Copy to .env.infrastructure.local and fill real values.
# Never commit .env.infrastructure.local.

PROJECT_GITHUB_ACCOUNT=REPLACE_WITH_APPROVED_GITHUB_ACCOUNT
PROJECT_GITHUB_ORG=FairfieldPolo
PROJECT_GITHUB_REPO=FairfieldPoloWebsite

PROJECT_WORKSPACE_ROOT=/home/REPLACE_WITH_USER/projects/FairfieldPolo

# Public site + optional shop / members hosts
PROJECT_SITE_URL=https://fairfieldpolo.com
PROJECT_SITE_HOSTNAMES=fairfieldpolo.com,www.fairfieldpolo.com

# Optional: set when shop or members run on separate hosts
# PROJECT_SHOP_HOSTNAME=shop.fairfieldpolo.com
# PROJECT_MEMBERS_HOSTNAME=members.fairfieldpolo.com

# Cloudflare DNS for fairfieldpolo.com (apex/www → Vercel today)
PROJECT_CLOUDFLARE_ZONE_NAME=fairfieldpolo.com
PROJECT_CLOUDFLARE_HOSTNAMES=fairfieldpolo.com,www.fairfieldpolo.com
PROJECT_CLOUDFLARE_ACCOUNT_ID=REPLACE_WITH_APPROVED_ACCOUNT_ID
PROJECT_CLOUDFLARE_ZONE_ID=REPLACE_WITH_APPROVED_ZONE_ID
# Optional — not required while site is DNS → Vercel (no tunnel)
# PROJECT_CLOUDFLARE_TUNNEL_ID=REPLACE_WITH_APPROVED_TUNNEL_ID

# Vercel (optional — doctor warns if unset)
# PROJECT_VERCEL_PROJECT=fairfield-polo
# PROJECT_VERCEL_TEAM=

# Expected Sanity project id (must match .env.local NEXT_PUBLIC_SANITY_PROJECT_ID)
# PROJECT_SANITY_PROJECT_ID=REPLACE_WITH_SANITY_PROJECT_ID
# PROJECT_SANITY_DATASET=production
